# OAuth Client Credentials
# Obtain these from the Nova Act QA Studio web interface:
# Settings → OAuth Clients → Create New Client
OAUTH_CLIENT_ID=your-client-id-here
OAUTH_CLIENT_SECRET=your-client-secret-here

# Cognito Token Endpoint
# Format: https://{cognito-domain}.auth.{region}.amazoncognito.com/oauth2/token
# Replace {cognito-domain} with your Cognito user pool domain
# Replace {region} with your AWS region (e.g., us-east-1)
OAUTH_TOKEN_ENDPOINT=https://your-domain.auth.us-east-1.amazoncognito.com/oauth2/token

# Platform API Endpoint
# Format: https://{api-id}.execute-api.{region}.amazonaws.com/{stage}
# Replace {api-id} with your API Gateway ID
# Replace {region} with your AWS region
# Replace {stage} with your API stage (typically 'api')
API_ENDPOINT=https://your-api-id.execute-api.us-east-1.amazonaws.com/api

# Logging Level (optional)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO
