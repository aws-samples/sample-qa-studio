#!make

.DEFAULT_GOAL := help

help:
	@echo "Available targets:"
	@echo "  test_all          - Run all Go tests with coverage"
	@echo "  lambdas.build     - Build all Lambda functions"
	@echo "  lambdas.clean     - Clean up Lambda bootstrap binaries"
	@echo "  frontend.build    - Build React frontend"
	@echo "  docker.build      - Build worker Docker image"
	@echo "  docker.upload     - Upload worker image to ECR"
	@echo "  cdk.deploy        - Deploy CDK stack to AWS"
	@echo "  deploy            - Full deployment (build + deploy + cleanup)"
	@echo "  clean             - Clean up all build artifacts"

test_all:
	go test -p 1 -v -coverpkg=./... -coverprofile=profile.cov ./... && go tool cover -func profile.cov && rm -rf profile.cov

docker.build:
	cd worker/ && podman build --platform linux/arm64 -t {ecr-name} .

docker.upload:
	podman tag {ecr-name}:latest {ecr-uri}:latest
	aws ecr get-login-password --region {region} | podman login --username AWS --password-stdin {ecr-hostname}
	podman push {ecr-uri}:latest

frontend.build:
	cd frontend && npm run build

lambdas.build:
	for f in $$(find ${LAMBDA_FOLDER} -type d -maxdepth 1 -mindepth 1 -exec basename {} \;); do sh -c "cd ${LAMBDA_FOLDER}/$${f} && GOOS=linux GOARCH=arm64 go build -tags lambda.norpc -o bootstrap main.go && echo \"\033[0;32m OK \033[0m $${f}\""; done

lambdas.clean:
	@echo "Cleaning up Lambda bootstrap binaries..."
	@find lambda/cmd -name "bootstrap" -type f -delete 2>/dev/null || true
	@find lambda/cmd -name "test_build" -type f -delete 2>/dev/null || true
	@echo "Lambda binaries cleaned up"

clean: lambdas.clean
	@echo "All build artifacts cleaned up"

cdk.deploy:
	npx cdk deploy

# deploy: lambdas.build frontend.build cdk.deploy
deploy: lambdas.build frontend.build cdk.deploy lambdas.clean
