{
  "name": "nova-act-recorder",
  "version": "1.0.0",
  "description": "Chrome extension that records browser interactions and converts them to Nova Act SDK prompts",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint *.js",
    "check": "eslint *.js && vitest --run"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "fast-check": "^3.22.0",
    "vitest": "^2.1.0"
  }
}
