{
  "manifest_version": 3,
  "name": "Nova Act Recorder",
  "version": "1.0.0",
  "description": "Record browser interactions and convert them to Nova Act SDK prompts",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "clipboardWrite",
    "webNavigation",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Nova Act Recorder"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["types.js", "element-descriptor-core.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://nova.amazon.com/*"
      ],
      "js": ["playground-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
